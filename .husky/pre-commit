#!/usr/bin/env sh
set -e

pnpm exec lint-staged

# Reject any reintroduction of `prettier` in CI workflows or `prettier --check`
# anywhere in the repo. Local hooks must catch this before it ever ships.
node scripts/check-no-prettier-check.js

# Type check: prevents committing code with type errors.
# Takes ~4s — acceptable for pre-commit since type safety is a core quality gate.
pnpm exec tsc -b

# Check for circular chunk dependencies when chunk config changes
if git diff --cached --name-only | grep -q 'vite.config.ts'; then
  echo "vite.config.ts changed — checking for circular chunk dependencies..."
  node scripts/check-chunk-cycles.js
fi

# Clippy on the Rust crate when any file in it is staged. CI rejects warnings
# (-D warnings); catching it here saves the round-trip.
if git diff --cached --name-only | grep -q '^src/wasm/mdimension_core/'; then
  echo "src/wasm/mdimension_core/ changed — running cargo clippy..."
  cargo clippy --manifest-path src/wasm/mdimension_core/Cargo.toml --target wasm32-unknown-unknown -- -D warnings
fi
