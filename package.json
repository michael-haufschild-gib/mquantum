{
  "name": "mquantum",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite --port 3000",
    "build": "pnpm wasm:build && node scripts/check-untracked-imports.js && node scripts/check-wgsl-backticks.js && node scripts/check-detect-gpu-benchmarks.js && tsc -b && vite build && pnpm build:check",
    "build:web": "node scripts/check-untracked-imports.js && node scripts/check-wgsl-backticks.js && node scripts/check-detect-gpu-benchmarks.js && tsc -b && vite build && pnpm build:check",
    "build:check": "node scripts/check-chunk-cycles.js",
    "bundle:check": "node scripts/check-bundle-size.js",
    "gpu-benchmarks:check": "node scripts/check-detect-gpu-benchmarks.js",
    "gpu-benchmarks:sync": "node scripts/sync-detect-gpu-benchmarks.js",
    "wasm:build": "wasm-pack build ./src/wasm/mdimension_core --target web && rm -f ./src/wasm/mdimension_core/pkg/.gitignore",
    "wasm:build:validator": "wasm-pack build ./src/wasm/mdimension_core --target nodejs --out-dir pkg-validator --features wdw-validator && rm -f ./src/wasm/mdimension_core/pkg-validator/.gitignore",
    "preview": "vite preview",
    "test": "vitest run",
    "test:rust": "cargo test --manifest-path src/wasm/mdimension_core/Cargo.toml",
    "test:all": "pnpm test && pnpm test:rust",
    "test:watch": "vitest",
    "test:shaders": "WGSL_VALIDATE=1 vitest run src/tests/rendering/wgsl/wgslValidation.test.ts",
    "test:shaders:fast": "WGSL_VALIDATE=1 WGSL_MAX=2000 vitest run src/tests/rendering/wgsl/wgslValidation.test.ts",
    "test:shaders:tint": "WGSL_TINT=1 playwright test scripts/playwright/wgsl-tint-validation.spec.ts",
    "lint": "eslint . --max-warnings 0 --no-warn-ignored",
    "lint:css": "stylelint \"src/**/*.css\" --max-warnings 0",
    "lint:rust": "cargo clippy --manifest-path src/wasm/mdimension_core/Cargo.toml",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:rust": "cargo fmt --manifest-path src/wasm/mdimension_core/Cargo.toml",
    "test:mutate": "stryker run",
    "test:mutate:incremental": "stryker run --incremental",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vercel/analytics": "^2.0.1",
    "detect-gpu": "^5.0.70",
    "fzstd": "^0.1.1",
    "mediabunny": "^1.27.4",
    "motion": "^12.24.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/expect": "^4.1.0",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.0.0",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-testing-library": "^7.16.1",
    "fast-check": "^4.6.0",
    "globals": "^17.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "playwright": "^1.57.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.1",
    "sharp": "^0.34.5",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-prune": "^0.10.3",
    "ttf2woff2": "^8.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "fsevents",
      "sharp",
      "ttf2woff2"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead",
    "not op_mini all",
    "not ie <= 11",
    "not safari < 12",
    "not android < 6"
  ]
}
