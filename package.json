{
  "name": "mdimension",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --port 3000",
    "build": "npm run wasm:build && tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "wasm:build": "wasm-pack build ./src/wasm/mdimension_core --target web && rm -f ./src/wasm/mdimension_core/pkg/.gitignore",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:rust": "cargo clippy --manifest-path src/wasm/mdimension_core/Cargo.toml",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:rust": "cargo fmt --manifest-path src/wasm/mdimension_core/Cargo.toml"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "convex-hull": "^1.0.3",
    "detect-gpu": "^5.0.70",
    "ktx-parse": "^1.1.0",
    "mediabunny": "^1.27.4",
    "motion": "^12.24.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.9",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@webgpu/types": "^0.1.69",
    "comlink": "^4.4.2",
    "eslint": "^9.15.0",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.14",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.0.0",
    "happy-dom": "^20.1.0",
    "playwright": "^1.57.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.1",
    "sharp": "^0.34.5",
    "ttf2woff2": "^8.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vite-plugin-wasm-pack": "^0.1.12",
    "vitest": "^4.0.15"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead",
    "not op_mini all",
    "not ie <= 11",
    "not safari < 12",
    "not android < 6"
  ]
}
